APP_ENV=development
SECRET_KEY=dev-secret-change-me
JWT_SECRET_KEY=dev-jwt-secret-change-me
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/library
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRES_SECONDS=1209600
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_CSRF_PROTECT=false
BOOTSTRAP_ADMIN=true
BOOTSTRAP_ADMIN_EMAIL=admin@book.com
BOOTSTRAP_ADMIN_PASSWORD=admin@password

BOOKS_CACHE_TTL_SECONDS=120
BORROWS_CACHE_TTL_SECONDS=60
SQLALCHEMY_ECHO=false

POSTGRES_DB=library
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
REDIS_PORT=6379
BACKEND_PORT=8000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
